# Application
NODE_ENV=production
PORT=3105
APP_NAME=PatagonAPI

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=bd_patacon
DB_USER=root_patacon
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret

# Session
SESSION_SECRET=your-super-secret-session-key-change-this
SESSION_NAME=patacon_session
SESSION_MAX_AGE=86400000

# Security
CORS_ORIGIN=http://localhost
JWT_SECRET=your-jwt-secret-key-change-this

# Logging
LOG_LEVEL=info